:{$PORT:8080} {
    root * /srv

    # Root URL: detect browser language preference
    @root path /
    handle @root {
        @french header_regexp Accept-Language (?i)fr
        redir @french /fr/ temporary
        redir * /en/ temporary
    }

    # Shared static assets (CSS, JS, images, favicons)
    @static path /css/* /js/* /img/* /favicon* /robots.txt /sitemap.xml
    handle @static {
        file_server
    }

    # Custom 404 pages per language subtree
    handle /en/* {
        try_files {path} {path}/index.html /en/404.html
        file_server
    }

    handle /fr/* {
        try_files {path} {path}/index.html /fr/404.html
        file_server
    }

    # Fallback for any other path
    handle {
        redir * /en/ temporary
    }

    encode gzip
}
